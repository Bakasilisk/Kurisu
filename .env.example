# Discord Bot Token
# Replace 'your_bot_token_here' with your actual bot token from the Discord Developer Portal.
# Do not share this token or commit it to a public repository!
DISCORD_TOKEN=your_bot_token_here

# Sightengine AI-image detection (optional — enables the .aicheck command)
# Get free API credentials at https://sightengine.com
SIGHTENGINE_API_USER=
SIGHTENGINE_API_SECRET=

# trace.moe API key (optional — raises trace.moe quota; .trace works without it)
TRACE_MOE_API_KEY=
